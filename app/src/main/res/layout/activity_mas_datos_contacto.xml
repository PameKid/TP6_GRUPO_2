<?xml version="1.0" encoding="utf-8"?>
 <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MasDatosContactoActivity">

    <TextView
        android:id="@+id/tvDatosRecibidos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mas Datos Contacto"
        android:textSize="22sp"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <RadioGroup
        android:id="@+id/rgNivelEstudios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvDatosRecibidos"
        app:layout_constraintStart_toStartOf="parent">

        <RadioButton
            android:id="@+id/rbPrimarioIncompleto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Primario incompleto" />

        <RadioButton
            android:id="@+id/rbPrimarioCompleto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Primario completo" />

        <RadioButton
            android:id="@+id/rbSecundarioIncompleto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secundario incompleto" />

        <RadioButton
            android:id="@+id/rbSecundarioCompleto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secundario completo" />

        <RadioButton
            android:id="@+id/rbOtros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Otros" />

    </RadioGroup>

</androidx.constraintlayout.widget.ConstraintLayout>