<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDialogTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/detalle_contacto"
            android:textColor="?attr/colorPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:background="?attr/colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nombre_completo"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fecha_nacimiento"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogFechaNacimiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/colorOutlineVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/telefono"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogTelefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/correo_electronico"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/direccion"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/colorOutlineVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nivel_estudios"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogNivelEstudios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/intereses"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogIntereses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:lineSpacingExtra="4dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/colorOutlineVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/suscripcion_informacion"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogSuscripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>